# Copy to .env and fill in. Do not commit .env (already in .gitignore).
#
# ─── Deployment / RPC ───────────────────────────────────────────────────────
# Wallet that deploys Pulse + PulseGatedHook. Fund 0.8–1.0 ETH on Eth Sepolia.
DEPLOYER_KEY=0x...
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ─── Pulse / Hook addresses (filled in after Day 1 deploy) ──────────────────
PULSE_ADDRESS=0x...
HOOK_ADDRESS=0x...
POOL_MANAGER=0x...

# Canonical ERC-8004 (same address across Eth Sepolia, Base Sepolia, etc.). Don't redeploy.
IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713

# ─── Agent identity ─────────────────────────────────────────────────────────
# The wallet the agent uses to call Pulse.commit (the principal). Fund ~0.20 ETH.
AGENT_PRIVATE_KEY=0x...

# ERC-8004 token id minted in Step 1 of operator onboarding (decimal string)
AGENT_ID=

# ENS name registered for the agent on Sepolia ENS — must be owned by the
# agent EOA above (or a controller). The Public Resolver writes the
# {agentId, signerProvider, pulseHistory, description, avatar} text records.
AGENT_ENS_NAME=pulseagent.eth

# ─── TEE signer (production: 0G; demo: stand-in) ────────────────────────────
# 0G Compute broker — production path
ZG_BROKER_URL=https://...
ZG_API_KEY=
ZG_MODEL=deepseek-reasoner
ZG_SIGNER_ADDRESS=0x...

# Stand-in TEE signer used by the demo (private key, signing only — 0 ETH balance).
# Label clearly in UI: "Demo TEE Signer (stand-in)". Never send funds to this address.
DEMO_TEE_SIGNER_KEY=0x...

# ─── Uniswap Trading API ────────────────────────────────────────────────────
# Get a free key at https://hub.uniswap.org
UNISWAP_TRADING_API_KEY=

# ─── Bad actor / demo runner wallet (clicks Force Bad Swap) ─────────────────
# Can share with AGENT_PRIVATE_KEY for simplicity. Fund 0.10–0.15 ETH + test tokens.
DEMO_RUNNER_KEY=0x...

# ─── Watcher service ────────────────────────────────────────────────────────
# Used by scripts/watch-and-slash.ts to lock in Violated state when the hook
# reverts. This wallet only calls Pulse.reveal() — needs minimal gas (~0.05 ETH).
WATCHER_KEY=0x...

# ─── Web app (optional, set when deployed) ──────────────────────────────────
NEXT_PUBLIC_PULSE_ADDRESS=
NEXT_PUBLIC_HOOK_ADDRESS=
NEXT_PUBLIC_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_AGENT_ENS_NAME=pulseagent.eth
